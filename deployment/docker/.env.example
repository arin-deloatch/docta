# Docker Compose Environment Variables
# Copy to .env and fill in your credentials

# OAuth 2.0 Client Credentials
GRAPHQL_CLIENT_ID=your_client_id_here
GRAPHQL_CLIENT_SECRET=your_client_secret_here
GRAPHQL_TOKEN_URL=https://auth.example.com/oauth/token

# Apollo GraphQL headers
APOLLOGRAPHQL_CLIENT_NAME=apollo_client_name

# QA Generation (if enabled in config)
GOOGLE_API_KEY=your_google_api_key_for_qa_generation

# Optional: Custom CA certificate
# Mount your CA bundle as a volume and set path
# GRAPHQL_CERT_PATH=/app/certs/ca-bundle.crt
